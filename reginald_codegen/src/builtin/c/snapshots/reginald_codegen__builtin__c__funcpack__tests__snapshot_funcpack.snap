// Watchdog timer configurtion.
#define MAX77654_CNFG_WDT                   (0x17U) //!< CNFG_WDT register address
#define MAX77654_CNFG_WDT_RESET             (0x30U) //!< CNFG_WDT register reset value
#define MAX77654_CNFG_WDT_ALWAYSWRITE_MASK  (0xC0U) //!< CNFG_WDT register always write mask
#define MAX77654_CNFG_WDT_ALWAYSWRITE_VALUE (0x0U)  //!< CNFG_WDT register always write value

/** @brief Watchdog Timer Expired Action. Determines what the IC does after the watchdog timer expires. */
enum max77654_wdt_mode {
  /** @brief Expiration causes power-off. */
  MAX77654_WDT_MODE_PWR_OFF = 0x0U,
  /** @brief Expiration causes power-reset. */
  MAX77654_WDT_MODE_PWR_RESET = 0x1U,
};

static inline bool max77654_can_unpack_enum_wdt_mode(uint8_t val) {
  if (0x0U <= val && val <= 0x1U) return true;
  return false;
}

/** @brief Watchdog Timer Period. Sets tWD. Watchdog timer is reset to the programmed val as soon as this bitfield is changed. */
enum max77654_wdt_per {
  /** @brief 128 seconds */
  MAX77654_WDT_PER_128S = 0x3U,
  /** @brief 16 seconds */
  MAX77654_WDT_PER_16S = 0x0U,
  /** @brief 32 seconds */
  MAX77654_WDT_PER_32S = 0x1U,
  /** @brief 64 seconds */
  MAX77654_WDT_PER_64S = 0x2U,
};

static inline bool max77654_can_unpack_enum_wdt_per(uint8_t val) {
  if (0x0U <= val && val <= 0x3U) return true;
  return false;
}

/**
 * @brief Watchdog timer configurtion.
 * @note use pack/unpack/overwrite functions for conversion to/from packed register value
 */
struct max77654_cnfg_wdt {
  /** @brief Watchdog Timer Clear Control. Set this bit to feed (reset) the WDT. */
  uint8_t wdt_clr : 1;
  /** @brief Watchdog Timer Enable. Write protected. */
  max77654_en wdt_en : 1;
  /** @brief Factory-Set Safety Bit for the Watchdog Timer. Prevent WDT from being disabled via WDT_EN. */
  max77654_en wdt_lock : 1;
  /** @brief Watchdog Timer Expired Action. Determines what the IC does after the watchdog timer expires. */
  max77654_wdt_mode wdt_mode : 1;
  /** @brief Watchdog Timer Period. Sets tWD. Watchdog timer is reset to the programmed val as soon as this bitfield is changed. */
  max77654_wdt_per wdt_per : 2;
};

/**
 * @brief Convert register struct to packed register value
 * All bits that are not part of a field or specified as 'always write' are kept as in 'val'.
 */
static inline uint8_t max77654_cnfg_wdt_overwrite(const struct max77654_cnfg_wdt *r, uint8_t val) {
  val &= ~(uint8_t)MAX77654_CNFG_WDT_ALWAYSWRITE_MASK;
  val |= MAX77654_CNFG_WDT_ALWAYSWRITE_VALUE;
  val &= ~(uint8_t)0x4U;
  val |= (((uint8_t)r->wdt_clr) & 0x1U) << (uint8_t)2U;
  val &= ~(uint8_t)0x2U;
  val |= (((uint8_t)r->wdt_en) & 0x1U) << (uint8_t)1U;
  val &= ~(uint8_t)0x1U;
  val |= (((uint8_t)r->wdt_lock) & 0x1U) << (uint8_t)0U;
  val &= ~(uint8_t)0x8U;
  val |= (((uint8_t)r->wdt_mode) & 0x1U) << (uint8_t)3U;
  val &= ~(uint8_t)0x30U;
  val |= (((uint8_t)r->wdt_per) & 0x3U) << (uint8_t)4U;
  return val;
}

/** @brief Convert register struct to packed register value */
static inline uint8_t max77654_cnfg_wdt_pack(const struct max77654_cnfg_wdt *r) {
  return max77654_cnfg_wdt_overwrite(r, 0);
}

/** @brief Convert packed register value to register struct initialization */
#define MAX77654_CNFG_WDT_UNPACK(_VAL_) {                                                          \
  .wdt_clr = ((_VAL_) >> 2U) & 0x1U,                                                               \
  .wdt_en = ((_VAL_) >> 1U) & 0x1U,                                                                \
  .wdt_lock = ((_VAL_) >> 0U) & 0x1U,                                                              \
  .wdt_mode = ((_VAL_) >> 3U) & 0x1U,                                                              \
  .wdt_per = ((_VAL_) >> 4U) & 0x3U,                                                               \
}}

/** @brief Convert packed register value into a register struct. */
static inline void max77654_cnfg_wdt_unpack_into(uint8_t val,  struct max77654_cnfg_wdt *r) {
  r->wdt_clr = (val >> 2U) & 0x1U;
  r->wdt_en = (max77654_en)((val >> 1U) & 0x1U);
  r->wdt_lock = (max77654_en)((val >> 0U) & 0x1U);
  r->wdt_mode = (max77654_wdt_mode)((val >> 3U) & 0x1U);
  r->wdt_per = (max77654_wdt_per)((val >> 4U) & 0x3U);
}

// ==== ERC_FLAG Register ======================================================
// Fault Status Register
#define MAX77654_ERC_FLAG       (0x5U) //!< ERC_FLAG register address
#define MAX77654_ERC_FLAG_RESET (0x0U) //!< ERC_FLAG register reset value

/**
 * @brief Fault Status Register
 * @note use pack/unpack/overwrite functions for conversion to/from packed register value
 */
struct max77654_erc_flag {
  /** @brief Manual Reset Timer */
  uint8_t mrst : 1;
  /** @brief Software Cold Reset Flag */
  uint8_t sft_crst_f : 1;
  /** @brief Software OFF Flag */
  uint8_t sft_off_f : 1;
  /** @brief SYS Domain Overvoltage Lockout */
  uint8_t sysovlo : 1;
  /** @brief SYS Domain Undervoltage Lockout */
  uint8_t sysuvlo : 1;
  /** @brief Thermal Overload */
  uint8_t tovld : 1;
  /**
   * @brief Watchdog Timer OFF Flag
   * This bit sets when the watchdog timer expires and causes a power-off (WDT_MODE = 0).
   */
  uint8_t wdt_off : 1;
  /**
   * @brief Watchdog Timer Reset Flag
   * This bit sets when the watchdog timer expires and causes a power-reset (WDT_MODE = 1).
   */
  uint8_t wdt_rst : 1;
};

/**
 * @brief Convert register struct to packed register value
 * All bits that are not part of a field or specified as 'always write' are kept as in 'val'.
 */
static inline uint8_t max77654_erc_flag_overwrite(const struct max77654_erc_flag *r, uint8_t val) {
  val &= ~(uint8_t)0x8U;
  val |= (((uint8_t)r->mrst) & 0x1U) << (uint8_t)3U;
  val &= ~(uint8_t)0x20U;
  val |= (((uint8_t)r->sft_crst_f) & 0x1U) << (uint8_t)5U;
  val &= ~(uint8_t)0x10U;
  val |= (((uint8_t)r->sft_off_f) & 0x1U) << (uint8_t)4U;
  val &= ~(uint8_t)0x2U;
  val |= (((uint8_t)r->sysovlo) & 0x1U) << (uint8_t)1U;
  val &= ~(uint8_t)0x4U;
  val |= (((uint8_t)r->sysuvlo) & 0x1U) << (uint8_t)2U;
  val &= ~(uint8_t)0x1U;
  val |= (((uint8_t)r->tovld) & 0x1U) << (uint8_t)0U;
  val &= ~(uint8_t)0x40U;
  val |= (((uint8_t)r->wdt_off) & 0x1U) << (uint8_t)6U;
  val &= ~(uint8_t)0x80U;
  val |= (((uint8_t)r->wdt_rst) & 0x1U) << (uint8_t)7U;
  return val;
}

/** @brief Convert register struct to packed register value */
static inline uint8_t max77654_erc_flag_pack(const struct max77654_erc_flag *r) {
  return max77654_erc_flag_overwrite(r, 0);
}

/** @brief Convert packed register value to register struct initialization */
#define MAX77654_ERC_FLAG_UNPACK(_VAL_) {                                                          \
  .mrst = ((_VAL_) >> 3U) & 0x1U,                                                                  \
  .sft_crst_f = ((_VAL_) >> 5U) & 0x1U,                                                            \
  .sft_off_f = ((_VAL_) >> 4U) & 0x1U,                                                             \
  .sysovlo = ((_VAL_) >> 1U) & 0x1U,                                                               \
  .sysuvlo = ((_VAL_) >> 2U) & 0x1U,                                                               \
  .tovld = ((_VAL_) >> 0U) & 0x1U,                                                                 \
  .wdt_off = ((_VAL_) >> 6U) & 0x1U,                                                               \
  .wdt_rst = ((_VAL_) >> 7U) & 0x1U,                                                               \
}}

/** @brief Convert packed register value into a register struct. */
static inline void max77654_erc_flag_unpack_into(uint8_t val,  struct max77654_erc_flag *r) {
  r->mrst = (val >> 3U) & 0x1U;
  r->sft_crst_f = (val >> 5U) & 0x1U;
  r->sft_off_f = (val >> 4U) & 0x1U;
  r->sysovlo = (val >> 1U) & 0x1U;
  r->sysuvlo = (val >> 2U) & 0x1U;
  r->tovld = (val >> 0U) & 0x1U;
  r->wdt_off = (val >> 6U) & 0x1U;
  r->wdt_rst = (val >> 7U) & 0x1U;
}

// ==== INTM_CHG Register ======================================================
// Charger Interrupt masking
#define MAX77654_INTM_CHG                   (0x7U)  //!< INTM_CHG register address
#define MAX77654_INTM_CHG_RESET             (0x0U)  //!< INTM_CHG register reset value
#define MAX77654_INTM_CHG_ALWAYSWRITE_MASK  (0x80U) //!< INTM_CHG register always write mask
#define MAX77654_INTM_CHG_ALWAYSWRITE_VALUE (0x0U)  //!< INTM_CHG register always write value

/**
 * @brief Charger Interrupt masking
 * @note use pack/unpack/overwrite functions for conversion to/from packed register value
 */
struct max77654_intm_chg {
  /** @brief CHGIN Control-Loop Related Interrupt Mask/disabled. */
  max77654_int_mask chgin_ctrl_i : 1;
  /** @brief CHGIN Related Interrupt Mask/disabled. */
  max77654_int_mask chgin_i : 1;
  /** @brief Charger Related Interrupt Mask/disabled. */
  max77654_int_mask chg_i : 1;
  /** @brief System Voltage Configuration Error Interrupt Mask/disabled */
  max77654_int_mask sys_cnfg_i : 1;
  /** @brief Minimum System Voltage Regulation-Loop Related Interrupt Mask/disabled */
  max77654_int_mask sys_ctrl_i : 1;
  /** @brief Thermistor Related Interrupt Mask/disabled. */
  max77654_int_mask thm_i : 1;
  /** @brief Die Junction Temperature Regulation Interrupt Mask/disabled. */
  max77654_int_mask tj_reg_i : 1;
};

/**
 * @brief Convert register struct to packed register value
 * All bits that are not part of a field or specified as 'always write' are kept as in 'val'.
 */
static inline uint8_t max77654_intm_chg_overwrite(const struct max77654_intm_chg *r, uint8_t val) {
  val &= ~(uint8_t)MAX77654_INTM_CHG_ALWAYSWRITE_MASK;
  val |= MAX77654_INTM_CHG_ALWAYSWRITE_VALUE;
  val &= ~(uint8_t)0x10U;
  val |= (((uint8_t)r->chgin_ctrl_i) & 0x1U) << (uint8_t)4U;
  val &= ~(uint8_t)0x4U;
  val |= (((uint8_t)r->chgin_i) & 0x1U) << (uint8_t)2U;
  val &= ~(uint8_t)0x2U;
  val |= (((uint8_t)r->chg_i) & 0x1U) << (uint8_t)1U;
  val &= ~(uint8_t)0x40U;
  val |= (((uint8_t)r->sys_cnfg_i) & 0x1U) << (uint8_t)6U;
  val &= ~(uint8_t)0x20U;
  val |= (((uint8_t)r->sys_ctrl_i) & 0x1U) << (uint8_t)5U;
  val &= ~(uint8_t)0x1U;
  val |= (((uint8_t)r->thm_i) & 0x1U) << (uint8_t)0U;
  val &= ~(uint8_t)0x8U;
  val |= (((uint8_t)r->tj_reg_i) & 0x1U) << (uint8_t)3U;
  return val;
}

/** @brief Convert register struct to packed register value */
static inline uint8_t max77654_intm_chg_pack(const struct max77654_intm_chg *r) {
  return max77654_intm_chg_overwrite(r, 0);
}

/** @brief Convert packed register value to register struct initialization */
#define MAX77654_INTM_CHG_UNPACK(_VAL_) {                                                          \
  .chgin_ctrl_i = ((_VAL_) >> 4U) & 0x1U,                                                          \
  .chgin_i = ((_VAL_) >> 2U) & 0x1U,                                                               \
  .chg_i = ((_VAL_) >> 1U) & 0x1U,                                                                 \
  .sys_cnfg_i = ((_VAL_) >> 6U) & 0x1U,                                                            \
  .sys_ctrl_i = ((_VAL_) >> 5U) & 0x1U,                                                            \
  .thm_i = ((_VAL_) >> 0U) & 0x1U,                                                                 \
  .tj_reg_i = ((_VAL_) >> 3U) & 0x1U,                                                              \
}}

/** @brief Convert packed register value into a register struct. */
static inline void max77654_intm_chg_unpack_into(uint8_t val,  struct max77654_intm_chg *r) {
  r->chgin_ctrl_i = (max77654_int_mask)((val >> 4U) & 0x1U);
  r->chgin_i = (max77654_int_mask)((val >> 2U) & 0x1U);
  r->chg_i = (max77654_int_mask)((val >> 1U) & 0x1U);
  r->sys_cnfg_i = (max77654_int_mask)((val >> 6U) & 0x1U);
  r->sys_ctrl_i = (max77654_int_mask)((val >> 5U) & 0x1U);
  r->thm_i = (max77654_int_mask)((val >> 0U) & 0x1U);
  r->tj_reg_i = (max77654_int_mask)((val >> 3U) & 0x1U);
}

