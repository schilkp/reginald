 * @brief Global Configuration
 * @note use pack/unpack/overwrite functions for conversion to/from packed register value
 */
struct max77654_cnfg_glbl {
  /** @brief Debounce Timer Enable for the nEN Pin */
  max77654_dben_nen dben_nen : 1;
  /** @brief nEN Internal Pullup Resistor */
  max77654_pu_dis pu_dis : 1;
  /** @brief Main Bias Force Enable Software Request */
  max77654_en sbia_en : 1;
  /** @brief Main Bias Low-Power Mode Software Request */
  uint8_t sbia_lpm : 1;
  /**
   * @brief Software Reset Function
   * Note that the SFT_CRST and SFT_OFF commands initiate the power-down sequence flow as described in the data sheet. This power-down sequence flow has delay elements that add up to 205.24ms (60ms delay + 10.24ms nRST assert delay + 4x2.56ms power-down slot delays + 125ms output discharge delay). If issuing the SFT_CRST and/or SFT_OFF functions in software, wait for more than 300ms before trying to issue any additional commands through I2C.
   */
  max77654_sft_ctrl sft_ctrl : 2;
  /** @brief Sets the Manual Reset Time (tMRST) */
  max77654_t_mrst t_mrst : 1;
  /** @brief nEN Input (ON-KEY) Default Configuration */
  max77654_nen_mode nen_mode : 1;
};

/**
 * @brief Convert register struct to packed register value
 * All bits that are not part of a field or specified as 'always write' are kept as in 'val'.
 */
static inline uint8_t max77654_cnfg_glbl_overwrite(const struct max77654_cnfg_glbl *r, uint8_t val) {
  val &= ~(uint8_t)0x4U;
  val |= (((uint8_t)r->dben_nen) & 0x1U) << (uint8_t)2U;
  val &= ~(uint8_t)0x80U;
  val |= (((uint8_t)r->pu_dis) & 0x1U) << (uint8_t)7U;
  val &= ~(uint8_t)0x10U;
