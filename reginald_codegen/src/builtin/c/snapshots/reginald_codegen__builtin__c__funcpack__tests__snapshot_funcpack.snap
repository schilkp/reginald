// ==== STAT_CHG_A Register ====================================================
// Charger status register A.
#define MAX77654_STAT_CHG_A                   (0x2U)  //!< STAT_CHG_A register address
#define MAX77654_STAT_CHG_A_RESET             (0x0U)  //!< STAT_CHG_A register reset value
#define MAX77654_STAT_CHG_A_ALWAYSWRITE_MASK  (0x80U) //!< STAT_CHG_A register always write mask
#define MAX77654_STAT_CHG_A_ALWAYSWRITE_VALUE (0x0U)  //!< STAT_CHG_A register always write value

/** @brief Battery Temperature Details. Valid only when CHGIN_DTLS[1:0] = 0b11. */
enum max77654_thm_dtls {
  /**
   * @brief Battery is cold as programmed by THM_COLD[1:0].
   * If thermistor and charger are enabled while the battery is cold, a battery temperature fault occurs.
   */
  MAX77654_THM_DTLS_THM_COLD = 0x1U,
  /** @brief Battery is cool as programmed by THM_COOL[1:0]. */
  MAX77654_THM_DTLS_THM_COOL = 0x2U,
  /**
   * @brief Battery is hot as programmed by THM_HOT[1:0].
   * If thermistor and charger are enabled while the battery is hot, a battery temperature fault occurs.
   */
  MAX77654_THM_DTLS_THM_HOT = 0x4U,
  /** @brief Thermistor is disabled (THM_EN = 0). */
  MAX77654_THM_DTLS_THM_OFF = 0x0U,
  /** @brief Battery is in the normal temperature region. */
  MAX77654_THM_DTLS_THM_OK = 0x5U,
  /** @brief Battery is warm as programmed by THM_WARM[1:0]. */
  MAX77654_THM_DTLS_THM_WARM = 0x3U,
};

static inline bool max77654_can_unpack_enum_thm_dtls(uint8_t val) {
  if (0x0U <= val && val <= 0x5U) return true;
  return false;
}

/**
 * @brief Charger status register A.
 * @note use pack/unpack/overwrite functions for conversion to/from packed register value
 */
struct max77654_stat_chg_a {
  /** @brief Input Current Limit Loop engaged. */
  uint8_t ichgin_lim_stat : 1;
  /** @brief Battery Temperature Details. Valid only when CHGIN_DTLS[1:0] = 0b11. */
  max77654_thm_dtls thm_dtls : 3;
  /** @brief Maximum Junction Temperature Regulation engaged. */
  uint8_t tj_reg_stat : 1;
  /** @brief Minimum Input Voltage Regulation Loop engaged. */
  uint8_t vchgin_min_stat : 1;
  /** @brief Minimum System Voltage Regulation Loop engaged. */
  uint8_t vsys_min_stat : 1;
};

/**
 * @brief Convert register struct to packed register value
 * All bits that are not part of a field or specified as 'always write' are kept as in 'val'.
 */
static inline uint8_t max77654_stat_chg_a_overwrite(const struct max77654_stat_chg_a *r, uint8_t val) {
  val &= ~(uint8_t)MAX77654_STAT_CHG_A_ALWAYSWRITE_MASK;
  val |= MAX77654_STAT_CHG_A_ALWAYSWRITE_VALUE;
  val &= ~(uint8_t)0x20U;
  val |= (((uint8_t)r->ichgin_lim_stat) & 0x1U) << (uint8_t)5U;
  val &= ~(uint8_t)0x7U;
  val |= (((uint8_t)r->thm_dtls) & 0x7U) << (uint8_t)0U;
  val &= ~(uint8_t)0x8U;
  val |= (((uint8_t)r->tj_reg_stat) & 0x1U) << (uint8_t)3U;
  val &= ~(uint8_t)0x40U;
  val |= (((uint8_t)r->vchgin_min_stat) & 0x1U) << (uint8_t)6U;
  val &= ~(uint8_t)0x10U;
  val |= (((uint8_t)r->vsys_min_stat) & 0x1U) << (uint8_t)4U;
  return val;
}

/** @brief Convert register struct to packed register value */
static inline uint8_t max77654_stat_chg_a_pack(const struct max77654_stat_chg_a *r) {
  return max77654_stat_chg_a_overwrite(r, 0);
}

/** @brief Convert packed register value to register struct initialization */
#define MAX77654_STAT_CHG_A_UNPACK(_VAL_) {                                                        \
  .ichgin_lim_stat = ((_VAL_) >> 5U) & 0x1U,                                                       \
  .thm_dtls = ((_VAL_) >> 0U) & 0x7U,                                                              \
  .tj_reg_stat = ((_VAL_) >> 3U) & 0x1U,                                                           \
  .vchgin_min_stat = ((_VAL_) >> 6U) & 0x1U,                                                       \
  .vsys_min_stat = ((_VAL_) >> 4U) & 0x1U,                                                         \
}}

/** @brief Convert packed register value into a register struct. */
static inline void max77654_stat_chg_a_unpack_into(uint8_t val,  struct max77654_stat_chg_a *r) {
  r->ichgin_lim_stat = (val >> 5U) & 0x1U;
  r->thm_dtls = (max77654_thm_dtls)((val >> 0U) & 0x7U);
  r->tj_reg_stat = (val >> 3U) & 0x1U;
  r->vchgin_min_stat = (val >> 6U) & 0x1U;
  r->vsys_min_stat = (val >> 4U) & 0x1U;
}

// ==== STAT_CHG_B Register ====================================================
// Charger status register B.
#define MAX77654_STAT_CHG_B       (0x3U) //!< STAT_CHG_B register address
#define MAX77654_STAT_CHG_B_RESET (0x0U) //!< STAT_CHG_B register reset value

/** @brief CHGIN Status details */
enum max77654_chgin_dtls {
  /** @brief The CHGIN input is being debounced (no power accepted from CHGIN during debounce). */
  MAX77654_CHGIN_DTLS_DBNC = 0x2U,
  /** @brief The CHGIN input is okay and debounced. */
  MAX77654_CHGIN_DTLS_OK = 0x3U,
  /** @brief The CHGIN input voltage is above the OVP threshold (VCHGIN > VOVP). */
  MAX77654_CHGIN_DTLS_OVP = 0x1U,
  /** @brief The CHGIN input voltage is below the UVLO threshold (VCHGIN < VUVLO). */
  MAX77654_CHGIN_DTLS_UVLO = 0x0U,
};

static inline bool max77654_can_unpack_enum_chgin_dtls(uint8_t val) {
  if (0x0U <= val && val <= 0x3U) return true;
  return false;
}

/** @brief Charger Status details */
enum max77654_chg_dtls {
  /** @brief Battery temperature fault. */
  MAX77654_CHG_DTLS_BAT_TEMP_FAULT = 0xCU,
  /** @brief Fast-charge constant-current (CC) mode. */
  MAX77654_CHG_DTLS_CC = 0x2U,
  /** @brief JEITA modified fast-charge constant-current mode. */
  MAX77654_CHG_DTLS_CC_JEITA = 0x3U,
  /** @brief Fast-charge constant-voltage (CV)mode. */
  MAX77654_CHG_DTLS_CV = 0x4U,
  /** @brief JEITA modified fast-charge constant-voltage mode. */
  MAX77654_CHG_DTLS_CV_JEITA = 0x5U,
  /** @brief Done */
  MAX77654_CHG_DTLS_DONE = 0x8U,
  /** @brief JEITA modified done (done was entered through the JEITA-modified fast-charge states). */
  MAX77654_CHG_DTLS_DONE_JEITA = 0x9U,
  /** @brief Fast-charge timer fault. */
  MAX77654_CHG_DTLS_FASTCHG_TIMER_FAULT = 0xBU,
  /** @brief Off */
  MAX77654_CHG_DTLS_OFF = 0x0U,
  /** @brief Prequalification mode. */
  MAX77654_CHG_DTLS_PQ = 0x1U,
  /** @brief Prequalification timer fault. */
  MAX77654_CHG_DTLS_PQ_TIMER_FAULT = 0xAU,
  /** @brief Top-off mode. */
  MAX77654_CHG_DTLS_TOPOFF = 0x6U,
  /** @brief JEITA modified top-off mode. */
  MAX77654_CHG_DTLS_TOPOFF_JEITA = 0x7U,
};

static inline bool max77654_can_unpack_enum_chg_dtls(uint8_t val) {
  if (0x0U <= val && val <= 0xCU) return true;
  return false;
}

/**
 * @brief Charger status register B.
 * @note use pack/unpack/overwrite functions for conversion to/from packed register value
 */
struct max77654_stat_chg_b {
  /** @brief Quick Charger Status/Is charging. */
  uint8_t chg : 1;
  /** @brief CHGIN Status details */
  max77654_chgin_dtls chgin_dtls : 2;
  /** @brief Charger Status details */
  max77654_chg_dtls chg_dtls : 4;
  /** @brief Timer Suspend Indicator */
  uint8_t time_sus : 1;
};

/**
 * @brief Convert register struct to packed register value
 * All bits that are not part of a field or specified as 'always write' are kept as in 'val'.
 */
static inline uint8_t max77654_stat_chg_b_overwrite(const struct max77654_stat_chg_b *r, uint8_t val) {
  val &= ~(uint8_t)0x2U;
  val |= (((uint8_t)r->chg) & 0x1U) << (uint8_t)1U;
  val &= ~(uint8_t)0xCU;
  val |= (((uint8_t)r->chgin_dtls) & 0x3U) << (uint8_t)2U;
  val &= ~(uint8_t)0xF0U;
  val |= (((uint8_t)r->chg_dtls) & 0xFU) << (uint8_t)4U;
  val &= ~(uint8_t)0x1U;
  val |= (((uint8_t)r->time_sus) & 0x1U) << (uint8_t)0U;
  return val;
}

/** @brief Convert register struct to packed register value */
static inline uint8_t max77654_stat_chg_b_pack(const struct max77654_stat_chg_b *r) {
  return max77654_stat_chg_b_overwrite(r, 0);
}

/** @brief Convert packed register value to register struct initialization */
#define MAX77654_STAT_CHG_B_UNPACK(_VAL_) {                                                        \
  .chg = ((_VAL_) >> 1U) & 0x1U,                                                                   \
  .chgin_dtls = ((_VAL_) >> 2U) & 0x3U,                                                            \
  .chg_dtls = ((_VAL_) >> 4U) & 0xFU,                                                              \
  .time_sus = ((_VAL_) >> 0U) & 0x1U,                                                              \
}}

/** @brief Convert packed register value into a register struct. */
static inline void max77654_stat_chg_b_unpack_into(uint8_t val,  struct max77654_stat_chg_b *r) {
  r->chg = (val >> 1U) & 0x1U;
  r->chgin_dtls = (max77654_chgin_dtls)((val >> 2U) & 0x3U);
  r->chg_dtls = (max77654_chg_dtls)((val >> 4U) & 0xFU);
  r->time_sus = (val >> 0U) & 0x1U;
}

// ==== STAT_GLBL Register =====================================================
// Global Status
#define MAX77654_STAT_GLBL       (0x6U) //!< STAT_GLBL register address
#define MAX77654_STAT_GLBL_RESET (0x0U) //!< STAT_GLBL register reset value

/**
 * @brief Global Status
 * @note use pack/unpack/overwrite functions for conversion to/from packed register value
 */
struct max77654_stat_glbl {
  /** @brief Main Bias OK */
  uint8_t bok : 1;
  /** @brief Device Identification Bits for Metal Options (0 = MAX77654 1 = Reserved) */
  uint8_t didm : 1;
  /** @brief LDO0 in dropout */
  uint8_t dod0_s : 1;
  /** @brief LDO1 in dropout */
  uint8_t dod1_s : 1;
  /** @brief Debounced Status for the nEN Input */
  uint8_t stat_en : 1;
  /** @brief nIRQ active */
  uint8_t stat_irq : 1;
  /** @brief Thermal Alarm 1 active */
  uint8_t tjal1_s : 1;
  /** @brief Thermal Alarm 2 active */
  uint8_t tjal2_s : 1;
};

/**
 * @brief Convert register struct to packed register value
 * All bits that are not part of a field or specified as 'always write' are kept as in 'val'.
 */
static inline uint8_t max77654_stat_glbl_overwrite(const struct max77654_stat_glbl *r, uint8_t val) {
  val &= ~(uint8_t)0x40U;
  val |= (((uint8_t)r->bok) & 0x1U) << (uint8_t)6U;
  val &= ~(uint8_t)0x80U;
  val |= (((uint8_t)r->didm) & 0x1U) << (uint8_t)7U;
  val &= ~(uint8_t)0x20U;
  val |= (((uint8_t)r->dod0_s) & 0x1U) << (uint8_t)5U;
  val &= ~(uint8_t)0x10U;
  val |= (((uint8_t)r->dod1_s) & 0x1U) << (uint8_t)4U;
  val &= ~(uint8_t)0x2U;
  val |= (((uint8_t)r->stat_en) & 0x1U) << (uint8_t)1U;
  val &= ~(uint8_t)0x1U;
  val |= (((uint8_t)r->stat_irq) & 0x1U) << (uint8_t)0U;
  val &= ~(uint8_t)0x4U;
  val |= (((uint8_t)r->tjal1_s) & 0x1U) << (uint8_t)2U;
  val &= ~(uint8_t)0x8U;
  val |= (((uint8_t)r->tjal2_s) & 0x1U) << (uint8_t)3U;
  return val;
}

/** @brief Convert register struct to packed register value */
static inline uint8_t max77654_stat_glbl_pack(const struct max77654_stat_glbl *r) {
  return max77654_stat_glbl_overwrite(r, 0);
}

/** @brief Convert packed register value to register struct initialization */
#define MAX77654_STAT_GLBL_UNPACK(_VAL_) {                                                         \
  .bok = ((_VAL_) >> 6U) & 0x1U,                                                                   \
  .didm = ((_VAL_) >> 7U) & 0x1U,                                                                  \
  .dod0_s = ((_VAL_) >> 5U) & 0x1U,                                                                \
  .dod1_s = ((_VAL_) >> 4U) & 0x1U,                                                                \
  .stat_en = ((_VAL_) >> 1U) & 0x1U,                                                               \
  .stat_irq = ((_VAL_) >> 0U) & 0x1U,                                                              \
  .tjal1_s = ((_VAL_) >> 2U) & 0x1U,                                                               \
  .tjal2_s = ((_VAL_) >> 3U) & 0x1U,                                                               \
}}

/** @brief Convert packed register value into a register struct. */
static inline void max77654_stat_glbl_unpack_into(uint8_t val,  struct max77654_stat_glbl *r) {
  r->bok = (val >> 6U) & 0x1U;
  r->didm = (val >> 7U) & 0x1U;
  r->dod0_s = (val >> 5U) & 0x1U;
  r->dod1_s = (val >> 4U) & 0x1U;
  r->stat_en = (val >> 1U) & 0x1U;
  r->stat_irq = (val >> 0U) & 0x1U;
  r->tjal1_s = (val >> 2U) & 0x1U;
  r->tjal2_s = (val >> 3U) & 0x1U;
}

