  return false;
}

/**
 * @brief Charger Config register D.
 * @note use pack/unpack/overwrite functions for conversion to/from packed register value
 */
struct max77654_cnfg_chg_d {
  /** @brief Sets the die junction temperature regulation point, TJ-REG. */
  max77654_tj_reg tj_reg : 3;
  /**
   * @brief System Voltage Regulation (VSYS-REG)
   * This 5-bit configuration is a linear transfer function that starts at 4.1V and ends at 4.8V,
   * with 25mV increments. Program VSYS_REG to at least 200mV above the higher of VFAST-CHG and
   * VFAST-CHG-JEITA.
   */
  max77654_vsys_reg vsys_reg : 5;
};

/**
 * @brief Convert register struct to packed register value
 * All bits that are not part of a field or specified as 'always write' are kept as in 'val'.
 */
static inline uint8_t max77654_cnfg_chg_d_overwrite(const struct max77654_cnfg_chg_d *r, uint8_t val) {
  val &= ~(uint8_t)0xE0U;
  val |= (((uint8_t)r->tj_reg) & 0x7U) << (uint8_t)5U;
  val &= ~(uint8_t)0x1FU;
  val |= (((uint8_t)r->vsys_reg) & 0x1FU) << (uint8_t)0U;
  return val;
}

/** @brief Convert register struct to packed register value */
static inline uint8_t max77654_cnfg_chg_d_pack(const struct max77654_cnfg_chg_d *r) {
  return max77654_cnfg_chg_d_overwrite(r, 0);
}

/** @brief Convert packed register value to register struct initialization */
#define MAX77654_CNFG_CHG_D_UNPACK(_VAL_) {                                                        \
  .tj_reg = ((_VAL_) >> 5U) & 0x7U,                                                                \
  .vsys_reg = ((_VAL_) >> 0U) & 0x1FU,                                                             \
}}

/** @brief Convert packed register value into a register struct. */
static inline void max77654_cnfg_chg_d_unpack_into(uint8_t val,  struct max77654_cnfg_chg_d *r) {
  r->tj_reg = (max77654_tj_reg)((val >> 5U) & 0x7U);
