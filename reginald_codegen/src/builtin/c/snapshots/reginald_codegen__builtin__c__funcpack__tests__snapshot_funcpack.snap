/**
 * @brief Software Reset Function
 * Note that the SFT_CRST and SFT_OFF commands initiate the power-down sequence flow as described in the data sheet. This power-down sequence flow has delay elements that add up to 205.24ms (60ms delay + 10.24ms nRST assert delay + 4x2.56ms power-down slot delays + 125ms output discharge delay). If issuing the SFT_CRST and/or SFT_OFF functions in software, wait for more than 300ms before trying to issue any additional commands through I2C.
 */
enum max77654_sft_ctrl {
  /**
   * @brief Factory-ship mode enter (FSM).
   * The IC powers down, configuration registers reset, and the internal BATT to SYS switch opens. The device remains this way until a factory-ship mode exit event occurs.
   */
  MAX77654_SFT_CTRL_FSM = 0x3U,
  /** @brief No Action */
  MAX77654_SFT_CTRL_NO_ACTION = 0x0U,
  /**
   * @brief Software cold reset.
   * The device powers down, resets, and then powers up again.
   */
  MAX77654_SFT_CTRL_SFT_CRST = 0x1U,
  /**
   * @brief Software off.
   * The device powers down, resets, and then remains off and waiting for a wake-up event.
   */
  MAX77654_SFT_CTRL_SFT_OFF = 0x2U,
};

static inline bool max77654_can_unpack_enum_sft_ctrl(uint8_t val) {
  if (0x0U <= val && val <= 0x3U) return true;
  return false;
}

