// ==== INT_CHG Register =======================================================
// Charger Interrupt flag register
#define MAX77654_INT_CHG                   (0x1U)  //!< INT_CHG register address
#define MAX77654_INT_CHG_RESET             (0x0U)  //!< INT_CHG register reset value
#define MAX77654_INT_CHG_ALWAYSWRITE_MASK  (0x80U) //!< INT_CHG register always write mask
#define MAX77654_INT_CHG_ALWAYSWRITE_VALUE (0x0U)  //!< INT_CHG register always write value

/**
 * @brief Charger Interrupt flag register
 * @note use pack/unpack/overwrite functions for conversion to/from packed register value
 */
struct max77654_int_chg {
  /**
   * @brief CHGIN Control-Loop Related Interrupt.
   * This bit asserts when the input reaches current limit (ICHGIN-LIM) or VCHGIN falls below VCHGIN_MIN.
   */
  uint8_t chgin_ctrl_i : 1;
  /** @brief CHGIN Related Interrupt (CHGIN_DTLS has changed). */
  uint8_t chgin_i : 1;
  /** @brief Charger Related Interrupt (CHG_DTLS has changed). */
  uint8_t chg_i : 1;
  /**
   * @brief System Voltage Configuration Error Interrupt
   * Triggers if VSYS-REG <= VFAST- CHG + 200mV
   */
  uint8_t sys_cnfg_i : 1;
  /**
   * @brief Minimum System Voltage Regulation-Loop Related Interrupt
   * This interrupt signals a change in the status bit VSYS_MIN_STAT.
   */
  uint8_t sys_ctrl_i : 1;
  /** @brief Thermistor Related Interrupt (THM_DTLS has changed). */
  uint8_t thm_i : 1;
  /**
   * @brief Die Junction Temperature Regulation Interrupt.
   * This bit asserts when the die temperature (TJ) exceeds TJ-REG.
   */
  uint8_t tj_reg_i : 1;
};

/**
 * @brief Convert register struct to packed register value
 * All bits that are not part of a field or specified as 'always write' are kept as in 'val'.
 */
static inline uint8_t max77654_int_chg_overwrite(const struct max77654_int_chg *r, uint8_t val) {
  val &= ~(uint8_t)MAX77654_INT_CHG_ALWAYSWRITE_MASK;
  val |= MAX77654_INT_CHG_ALWAYSWRITE_VALUE;
  val &= ~(uint8_t)0x10U;
  val |= (((uint8_t)r->chgin_ctrl_i) & 0x1U) << (uint8_t)4U;
  val &= ~(uint8_t)0x4U;
  val |= (((uint8_t)r->chgin_i) & 0x1U) << (uint8_t)2U;
  val &= ~(uint8_t)0x2U;
  val |= (((uint8_t)r->chg_i) & 0x1U) << (uint8_t)1U;
  val &= ~(uint8_t)0x40U;
  val |= (((uint8_t)r->sys_cnfg_i) & 0x1U) << (uint8_t)6U;
  val &= ~(uint8_t)0x20U;
  val |= (((uint8_t)r->sys_ctrl_i) & 0x1U) << (uint8_t)5U;
  val &= ~(uint8_t)0x1U;
  val |= (((uint8_t)r->thm_i) & 0x1U) << (uint8_t)0U;
  val &= ~(uint8_t)0x8U;
  val |= (((uint8_t)r->tj_reg_i) & 0x1U) << (uint8_t)3U;
  return val;
}

/** @brief Convert register struct to packed register value */
static inline uint8_t max77654_int_chg_pack(const struct max77654_int_chg *r) {
  return max77654_int_chg_overwrite(r, 0);
}

/** @brief Convert packed register value to register struct initialization */
#define MAX77654_INT_CHG_UNPACK(_VAL_) {                                                           \
  .chgin_ctrl_i = ((_VAL_) >> 4U) & 0x1U,                                                          \
  .chgin_i = ((_VAL_) >> 2U) & 0x1U,                                                               \
  .chg_i = ((_VAL_) >> 1U) & 0x1U,                                                                 \
  .sys_cnfg_i = ((_VAL_) >> 6U) & 0x1U,                                                            \
  .sys_ctrl_i = ((_VAL_) >> 5U) & 0x1U,                                                            \
  .thm_i = ((_VAL_) >> 0U) & 0x1U,                                                                 \
  .tj_reg_i = ((_VAL_) >> 3U) & 0x1U,                                                              \
}}

/** @brief Convert packed register value into a register struct. */
static inline void max77654_int_chg_unpack_into(uint8_t val,  struct max77654_int_chg *r) {
  r->chgin_ctrl_i = (val >> 4U) & 0x1U;
  r->chgin_i = (val >> 2U) & 0x1U;
  r->chg_i = (val >> 1U) & 0x1U;
  r->sys_cnfg_i = (val >> 6U) & 0x1U;
  r->sys_ctrl_i = (val >> 5U) & 0x1U;
  r->thm_i = (val >> 0U) & 0x1U;
  r->tj_reg_i = (val >> 3U) & 0x1U;
}

